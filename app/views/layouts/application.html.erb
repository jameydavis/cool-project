<!DOCTYPE html>
<html lang="en" data-theme="system">
  <head>
    <title><%= content_for(:title) || "Cool Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Cool Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <script>
      (function () {
        var key = "cool-project-theme";
        var valid = ["neutral", "butter", "chocolate", "gothic", "matcha", "stone", "y2k"];
        var stored = localStorage.getItem(key) || "neutral";
        if (valid.indexOf(stored) === -1) stored = "neutral";
        document.documentElement.setAttribute("data-astryx-theme", stored);
        if (stored === "gothic") {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,400..700;1,400..700&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "astryx", "data-turbo-track": "reload" %>
  </head>

  <body>
    <div id="astryx-root"></div>
    <script type="application/json" id="astryx-props"><%= raw astryx_payload.to_json %></script>
    <%= javascript_include_tag "astryx_app", type: "module", "data-turbo-track": "reload" %>
  </body>
</html>
