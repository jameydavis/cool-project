#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

def configure_ruby_env!
  homebrew_ruby = "/opt/homebrew/opt/ruby/bin"
  gem_home = File.expand_path("~/.local/share/gem/ruby/4.0.0")

  if File.directory?(homebrew_ruby)
    ENV["PATH"] = "#{homebrew_ruby}:#{gem_home}/bin:#{ENV["PATH"]}"
  end
  ENV["GEM_HOME"] = gem_home
  ENV["GEM_PATH"] = "#{gem_home}:/opt/homebrew/lib/ruby/gems/4.0.0"
end

configure_ruby_env!

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bin/bundle check") || system!("bin/bundle install")
  system("npm install")
  system!("npm run build")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end
